#!/usr/bin/env sh
# Re-render any .mmd whose source was edited in this commit, and re-stage
# the matching .svg. Skipped when no .mmd files are staged.
#
# To enable this hook, run once after cloning:
#   git config core.hooksPath .githooks

set -e

staged_mmd=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.mmd$' || true)
if [ -z "$staged_mmd" ]; then
    exit 0
fi

if [ ! -d node_modules ]; then
    echo "pre-commit: installing dependencies (first run)…"
    npm install --silent
fi

for mmd in $staged_mmd; do
    svg="${mmd%.mmd}.svg"
    ./node_modules/.bin/mmdc --input "$mmd" --output "$svg" --outputFormat svg --quiet
    git add "$svg"
done
